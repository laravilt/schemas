{
    "name": "@laravilt/schemas",
    "version": "1.0.0",
    "description": "Layout and organizational components for Laravilt - Grid, Section, Tabs, Wizard",
    "type": "module",
    "main": "dist/schemas.umd.js",
    "module": "dist/schemas.es.js",
    "exports": {
        ".": {
            "import": "./dist/schemas.es.js",
            "require": "./dist/schemas.umd.js"
        },
        "./style.css": "./dist/schemas.css"
    },
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "vite build --mode production"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "autoprefixer": "^10.4.16",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.4.0",
        "vite": "^5.0.0",
        "vue": "^3.4.0"
    },
    "peerDependencies": {
        "vue": "^3.4"
    }
}
